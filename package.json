{
  "name": "wholesale-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run lib/order-intake.test.ts lib/orders.test.ts",
    "test:integration:db": "vitest run tests/integration/order-stock.test.ts",
    "test:security": "vitest run tests/security",
    "test:security:coverage": "vitest run tests/security --coverage",
    "test:security:ci": "vitest run tests/security --coverage --reporter=default --reporter=junit --outputFile.junit=reports/security-tests.xml",
    "test:regression": "node scripts/test-regression.mjs baseline",
    "test:regression:admin": "node scripts/test-regression.mjs baseline admin",
    "test:regression:auth": "node scripts/test-regression.mjs baseline auth",
    "test:regression:customers": "node scripts/test-regression.mjs baseline customers",
    "test:regression:db": "node scripts/test-regression.mjs baseline db",
    "test:regression:docs": "node scripts/test-regression.mjs baseline docs",
    "test:regression:full": "node scripts/test-regression.mjs full",
    "test:regression:imports": "node scripts/test-regression.mjs baseline imports",
    "test:regression:order": "node scripts/test-regression.mjs baseline order",
    "test:regression:products": "node scripts/test-regression.mjs baseline products",
    "test:regression:ui": "node scripts/test-regression.mjs baseline ui",
    "security:audit": "node scripts/security-audit.mjs",
    "security:gate": "npm run security:audit && npm run test:security:ci",
    "prepare": "node scripts/install-git-hooks.mjs",
    "docs:update": "node scripts/update-readme.mjs",
    "docs:check": "node scripts/update-readme.mjs --check",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:reset": "node scripts/reset.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:seed:activity-demo": "node scripts/seed-activity-demo.mjs",
    "db:fresh": "npm run db:reset && npm run db:seed",
    "admin:grant": "node scripts/grant-super-admin.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "read-excel-file": "^9.2.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "supabase": "^2.107.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
